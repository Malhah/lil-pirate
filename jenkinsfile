pipeline {
    agent any

    environment {
        IMAGE_NAME = 'lil-pirate'
        CONTAINER_NAME = 'lil-pirate-build'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Sources') {
            steps {
                bat '''
                if not exist src (
                    echo src folder not found
                    exit /b 1
                )

                dir /s /b src\\*.java
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build --no-cache -t %IMAGE_NAME% .'
            }
        }

        stage('Remove Old Container') {
            steps {
                bat '''
                docker rm -f %CONTAINER_NAME% 2>nul
                exit /b 0
                '''
            }
        }

        stage('Run Container') {
            steps {
                bat 'docker run --name %CONTAINER_NAME% %IMAGE_NAME%'
            }
        }

        stage('Show Container Logs') {
            steps {
                bat 'docker logs %CONTAINER_NAME%'
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully.'
        }

        failure {
            echo 'Pipeline failed.'
        }

        always {
            bat '''
            docker rm -f %CONTAINER_NAME% 2>nul
            exit /b 0
            '''
            cleanWs()
        }
    }
}